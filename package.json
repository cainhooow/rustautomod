{
  "name": "rustautomod",
  "displayName": "Rust AutoMod",
  "icon": "assets/automodlogo.png",
  "description": "Rust Automod is a Visual Studio Code extension that automates the management of mod.rs files in Rust projects. It eliminates the repetitive task of manually creating and maintaining module declarations, keeping your Rust project structure clean and organized.",
  "version": "1.3.0",
  "author": "Cainhooow - Caio Augusto",
  "publisher": "drkryz",
  "engines": {
    "vscode": "^1.108.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cainhooow/rustautomod"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:rust",
    "onFileSystem:*.rs",
    "workspaceContains:**/Cargo.toml",
    "onCommand:rustautomod.toggleHideModRs",
    "onCommand:rustautomod.hideThisModRs",
    "onCommand:rustautomod.restoreHiddenModRs"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "menus": {
      "commandPalette": [
        {
          "command": "rustautomod.toggleHideModRs"
        },
        {
          "command": "rustautomod.restoreHiddenModRs"
        }
      ],
      "explorer/context": [
        {
          "command": "rustautomod.hideThisModRs",
          "when": "resourceFilename == mod.rs",
          "group": "navigation@90"
        },
        {
          "command": "rustautomod.restoreHiddenModRs",
          "when": "resourceFilename == mod.rs",
          "group": "navigation@91"
        }
      ]
    },
    "commands": [
      {
        "title": "Toggle Smart mod.rs Hiding",
        "command": "rustautomod.toggleHideModRs",
        "shortTitle": "Toggle smart mod.rs hiding"
      },
      {
        "title": "Hide This mod.rs",
        "command": "rustautomod.hideThisModRs"
      },
      {
        "title": "Restore Hidden mod.rs",
        "command": "rustautomod.restoreHiddenModRs"
      }
    ],
    "configuration": {
      "title": "Rust Automod",
      "properties": {
        "rustautomod.visibility": {
          "type": "string",
          "enum": [
            "pub",
            "private"
          ],
          "default": "pub",
          "description": "Define rust modules create with public(pub mod) or private(mod)"
        },
        "rustautomod.sort": {
          "type": "string",
          "enum": [
            "alpha",
            "none"
          ],
          "default": "alpha",
          "description": "Define rust module organization"
        },
        "rustautomod.fmt": {
          "type": "string",
          "enum": [
            "enabled",
            "disabled"
          ],
          "default": "disabled",
          "description": "Define whether you want formatting with cargo fmt after deleting/creating mod.rs"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "yarn run compile && yarn run lint",
    "test:unit": "mocha --ui tdd out/test/modContentEditor.test.js out/test/modVisibility.test.js",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.0.6",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.38.0",
    "mocha": "^11.7.4",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
